{
  "name": "msocial-js-sdk",
  "version": "1.1.0",
  "description": "JavaScript SDK for msocial API (generated by orval)",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "msocial",
    "sdk",
    "api",
    "openapi",
    "axios"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lghdnov/msocial-js-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/lghdnov/msocial-js-sdk/issues"
  },
  "homepage": "https://github.com/lghdnov/msocial-js-sdk#readme",
  "license": "MIT",
  "peerDependencies": {
    "axios": ">=1.0.0"
  },
  "devDependencies": {
    "axios": "^1.8.0",
    "orval": "^8.12.3",
    "typescript": "^5.8.0"
  }
}
